<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Auto-Update Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Updates"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/autoUpdateSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable auto-update checks"
            android:checked="true"
            android:paddingVertical="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Automatically check for updates on app start"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="8dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginVertical="16dp" />

        <!-- IP Configuration Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Network Configuration"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/networkStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Network status: Checking..."
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/useDeviceIpSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Use Device Local IP"
            android:checked="true"
            android:paddingVertical="8dp" />

        <TextView
            android:id="@+id/deviceIpLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detected IP: Loading..."
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="8dp" />

        <!-- Custom IP Input Section -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/customIpLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Custom IP Address"
            android:enabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/customIpInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number|text"
                android:maxLines="1"
                android:imeOptions="actionDone" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter a custom IP address for ADB pairing (e.g., 192.168.1.100)"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="8dp" />

        <!-- IP Validation Error -->
        <TextView
            android:id="@+id/ipValidationError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="?android:attr/colorError"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginVertical="16dp" />

        <!-- Info Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About IP Configuration"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Device Local IP: Uses your phone's current WiFi IP address (recommended)\n• Custom IP: Use if your IP address changes frequently or you want to connect to a specific device"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Check for Updates Button -->
        <Button
            android:id="@+id/checkUpdateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check for Updates"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />

        <!-- Save Button -->
        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Settings"
            android:minHeight="48dp" />

    </LinearLayout>

</ScrollView>
